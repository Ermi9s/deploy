# ==============================================================================
# Ingestion Service Environment Variables Template
# ==============================================================================
# Note: Sensitive variables (DB_USER, DB_PASSWORD) are sourced from the global root .env file.
# ==============================================================================

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
WORKERS_INGEST_TASK_NAME=workers.handle_document_ingestion_job
DJANGO_SETTINGS_MODULE=ingestion.settings
GUNICORN_BIND=0.0.0.0:8000
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

UPLOAD_ROOT=/shared/uploads/

DB_NAME=okm_db
DB_HOST=postgres
DB_PORT=5432

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

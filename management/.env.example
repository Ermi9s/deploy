# ==============================================================================
# Management Service Environment Variables Template
# ==============================================================================
# Note: Sensitive variables (DB_USER, DB_PASSWORD, MINIO_ROOT_USER, MINIO_ROOT_PASSWORD)
# are sourced from the global root .env file.
# ==============================================================================

DJANGO_SETTINGS_MODULE=management.settings
GUNICORN_BIND=0.0.0.0:8000
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

DB_NAME=okm_db
DB_HOST=postgres
DB_PORT=5432

ALLOWED_HOSTS=localhost,127.0.0.1,management
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_PUBLIC_SECURE=false
MINIO_BUCKET=okm-files
MINIO_REGION=us-east-1
MINIO_SECURE=false

MAX_UPLOAD_SIZE_MB=500

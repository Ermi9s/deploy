# ==============================================================================
# Frontend (Next.js) Service Environment Variables Template
# ==============================================================================

# Internal service endpoints used by Next.js SSR inside the Docker network:
MANAGEMENT_API=http://management:8000
INGESTION_API=http://ingestion:8000
RAG_API=http://rag:8000
NOTIFICATION_API=http://notification:8000

# Client-facing public API URLs (for running frontend outside Docker):
NEXT_PUBLIC_MANAGEMENT_API=http://localhost:8002
NEXT_PUBLIC_INGESTION_API=http://localhost:8001

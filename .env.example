# ==============================================================================
# AI Office Knowledge Hub Platform - Global Environment Variables Template
# ==============================================================================
# Copy this file to '.env' and configure your secret credentials before running.
# DO NOT COMMIT THE ACTUAL '.env' FILE TO VERSION CONTROL.
# ==============================================================================

# Relational Database Configurations (PostgreSQL)
# ------------------------------------------------------------------------------
# These define the database name, username, and credentials created/used by postgres.
POSTGRES_USER=okm_user
POSTGRES_PASSWORD=your_secure_postgres_password_here
POSTGRES_DB=okm_db
POSTGRES_DB_NAME=okm_db

# Relational Database Client Credentials (used by Django services to connect)
# ------------------------------------------------------------------------------
DB_USER=okm_user
DB_PASSWORD=your_secure_postgres_password_here

# Object Storage Configurations (MinIO)
# ------------------------------------------------------------------------------
# Administrator username and password for MinIO object store console & API access.
MINIO_ROOT_USER=okm_minio_user
MINIO_ROOT_PASSWORD=your_secure_minio_secret_here

# LLM & Embedding API Keys (Google Gemini)
# ------------------------------------------------------------------------------
# Your Gemini API Key from Google AI Studio. Required for document embeddings & RAG.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Security Secrets (Shared JWT and Internal Service Communications)
# ------------------------------------------------------------------------------
# SHARED_JWT_SECRET: Must match across all services to sign/verify JWT tokens.
# PLANNING_SERVICE_SECRET: Internal token used to secure communication between planning components.
SHARED_JWT_SECRET=your_django_shared_jwt_secret_here
PLANNING_SERVICE_SECRET=your_planning_service_internal_secret_here

# Task Scheduling & Workers Config
# ------------------------------------------------------------------------------
MILESTONE_SWEEP_INTERVAL_HOURS=1

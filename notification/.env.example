# ==============================================================================
# Notification Service Environment Variables Template
# ==============================================================================
# Note: Sensitive variables (DB_USER, DB_PASSWORD, SHARED_JWT_SECRET, PLANNING_SERVICE_SECRET)
# are sourced from the global root .env file.
# ==============================================================================

DJANGO_SETTINGS_MODULE=notification.settings
DAPHNE_BIND=0.0.0.0
DAPHNE_PORT=8000

DB_NAME=okm_db
DB_HOST=postgres
DB_PORT=5432
REDIS_URL=redis://redis:6379/0
ALLOWED_HOSTS=localhost,127.0.0.1,notification

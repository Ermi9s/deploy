# ==============================================================================
# Workers Service Environment Variables Template
# ==============================================================================
# Note: Sensitive variables (DB_USER, DB_PASSWORD, GEMINI_API_KEY, PLANNING_SERVICE_SECRET)
# are sourced from the global root .env file.
# ==============================================================================

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
DJANGO_SETTINGS_MODULE=workers.settings
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX=documents_chunks
UPLOAD_ROOT=/shared/uploads
CELERY_APP=workers
CELERY_LOGLEVEL=info
CELERY_QUEUES=document_ingestion_jobs,report_generation_jobs,default
RAG_INTERNAL_URL=http://rag:8000
MILESTONE_SWEEP_INTERVAL_MINUTES=1

DB_NAME=okm_db
DB_HOST=postgres
DB_PORT=5432
REPORT_TOP_K_PER_AGENDA=3
